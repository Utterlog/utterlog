# ============================================================
# Utterlog 环境变量模板
# ------------------------------------------------------------
# 复制此文件为 .env 并按需修改：  cp .env.example .env
# Docker 用户：在 docker-compose.yml 中直接改 environment 即可
# ============================================================

# ---- 数据库 ----
DB_HOST=postgres
DB_PORT=5432
DB_NAME=utterlog
DB_USER=utterlog
# 留空 — deploy.sh / install.sh 会生成 16 位随机密码写入此处
DB_PASSWORD=
DB_PREFIX=ul_

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- API ----
PORT=8080
APP_URL=http://localhost:9260
# 留空 — deploy.sh / install.sh 会生成 48 位随机密钥
JWT_SECRET=

# ---- 对外端口（生产部署用）----
# 仅绑 127.0.0.1，不占用 80/443；nginx/caddy 反代到这里。
# 部署脚本会自动检测端口占用，被占则顺延到下一个可用端口。
UTTERLOG_PORT=9260

# ---- 文件存储（local 或 s3）----
STORAGE_DRIVER=local

# S3/R2 配置（STORAGE_DRIVER=s3 时生效）
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto
S3_PUBLIC_URL=

# ---- Web 前端 ----
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
INTERNAL_API_URL=http://api:8080/api/v1
