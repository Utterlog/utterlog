# ============================================================
# Utterlog — bundled Caddy reverse proxy (auto-TLS mode)
# ------------------------------------------------------------
# Loaded when COMPOSE_PROFILES=tls and DOMAIN env is set.
# Caddy automatically obtains & renews Let's Encrypt certificate.
#
# Uses internal docker network to reach api container —
# no host port binding needed for tls mode.
# ============================================================

{$DOMAIN:localhost} {
	# Automatic HTTPS + HTTP/3
	encode gzip zstd

	# Hash-immutable static assets — cache aggressively
	@static path /_next/static/* /admin/assets/*
	handle @static {
		header Cache-Control "public, max-age=31536000, immutable"
		reverse_proxy api:8080
	}

	# Everything else → Utterlog (Go, which proxies to Next.js internally)
	handle {
		reverse_proxy api:8080 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
			flush_interval -1
		}
	}

	# Security headers
	header {
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		-Server
	}

	request_body {
		max_size 100MB
	}
}
