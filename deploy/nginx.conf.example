# ============================================================
# Utterlog — nginx reverse proxy snippet
# ------------------------------------------------------------
# Usage:
#   1. Replace `blog.example.com` with your domain.
#   2. Replace the port 9260 with whatever `make deploy` printed.
#   3. Drop this into /etc/nginx/sites-available/ or conf.d/, then:
#        sudo nginx -t && sudo systemctl reload nginx
#
# TLS: this example assumes you already have a cert (e.g. from certbot)
#      at /etc/letsencrypt/live/<domain>/. Adjust paths if different.
# ============================================================

# --- HTTP → HTTPS redirect ---
server {
    listen 80;
    listen [::]:80;
    server_name blog.example.com;
    return 301 https://$host$request_uri;
}

# --- HTTPS main block ---
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name blog.example.com;

    # TLS (replace with your cert paths)
    ssl_certificate     /etc/letsencrypt/live/blog.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/blog.example.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Upload size limit — match whatever your admin media upload max is
    client_max_body_size 100M;

    # --- Main reverse proxy to Utterlog ---
    location / {
        proxy_pass http://127.0.0.1:9260;

        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;

        # WebSocket / SSE support (used by in-browser live preview, AI streaming)
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_buffering off;
        proxy_read_timeout 300s;
    }

    # --- Long-cache for Next.js static chunks ---
    location /_next/static/ {
        proxy_pass http://127.0.0.1:9260;
        proxy_cache_valid 200 1y;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # --- Long-cache for embedded admin SPA assets ---
    location /admin/assets/ {
        proxy_pass http://127.0.0.1:9260;
        proxy_cache_valid 200 1y;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }
}
