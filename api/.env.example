# ============================================================
# Utterlog API 环境变量
# ============================================================

# 数据库
DB_DRIVER=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=utterlog
DB_USER=utterlog
DB_PASSWORD=change-me
DB_PREFIX=ul_

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# 服务
PORT=8080
APP_URL=http://localhost:8080
JWT_SECRET=change-this-to-a-random-32char-string

# 存储（local 或 s3）
STORAGE_DRIVER=local
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto
S3_PUBLIC_URL=
