# ========================================
# AI Bridge - 托管模式配置示例
# 
# 此配置用于官方托管服务（如 us-aibridge.bluecdn.com）
# 需要配置 SITE_TOKEN 来启用 Token 申请功能
# ========================================

LISTEN_ADDR=:8080
DATA_DIR=./data

# ========================================
# 托管模式关键配置
# ========================================

# 管理员 Token（必需）
# 用于访问管理接口和验证用户申请的 Token
SITE_TOKEN=your-secure-admin-token-here

# ========================================
# 邮件配置（用于发送 Token 给用户）
# ========================================

EMAIL_PROVIDER=sendflare
EMAIL_API_KEY=your-api-key-here
EMAIL_FROM_ADDR=noreply@your-domain.com
EMAIL_FROM_NAME=AI Bridge

# ========================================
# 节点配置
# ========================================

NODE_NAME=us-aibridge
NODE_TRAFFIC_MODE=outbound

# 请求超时和限流
REQUEST_TIMEOUT_SECONDS=60
RATE_LIMIT_PER_MINUTE=120

# 默认模型
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4.1-mini

# ========================================
# AI 提供商配置
# ========================================

OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ========================================
# 可选配置
# ========================================

# 监控 Token（可选）
# METRICS_TOKEN=your-metrics-token
