{
  "name": "analytics",
  "displayName": "访问统计",
  "description": "在页面头部注入统计代码（Google Analytics / Umami / Plausible 等）",
  "version": "1.0.15",
  "author": "Utterlog",
  "hooks": {
    "head_scripts": "<script>/* analytics code here */</script>"
  },
  "settings": [
    { "key": "tracking_id", "label": "Tracking ID", "type": "text", "placeholder": "G-XXXXXXXXXX" },
    { "key": "provider", "label": "统计平台", "type": "select", "options": ["google", "umami", "plausible"], "default": "google" }
  ]
}
