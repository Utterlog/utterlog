# ============================================================
# Utterlog .gitignore
# ============================================================

# OS
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride

# Claude / local dev
.claude/
DEPLOY.md
DEVELOPMENT.md
/deploy.sh

# IDE
.idea/
.vscode/
*.swp
*.swo

# Dependencies
node_modules/
vendor/

# Environment (never commit real secrets)
.env
.env.local
.env.*.local
!.env.example
!**/.env.example

# Build
.next/
dist/
build/
out/

# Uploads (user data) — both the real dir and dev-only symlink to project-root uploads/
uploads/
api/public/uploads
api/public/uploads/
!api/public/uploads/.gitkeep

# Go binaries (compiled artifacts — built in CI / deploy)
api/utterlog-go
api/utterlog-api
api/utterlog-hub-linux
api/api
api/utterlog

# TypeScript incremental build info
*.tsbuildinfo

# Cache / logs
*.cache
*.log
logs/
/storage/
.phpunit.result.cache

# Docker volumes (user data)
pgdata/
redisdata/
data/

# Database / WordPress dumps (not part of source)
*.sql
*.sql.zip
*.sql.gz
*.xml
!api/schema.sql

# Backups (user data)
backups/
api/backups/

# Package locks (keep package-lock.json for npm; exclude others)
yarn.lock
pnpm-lock.yaml

# Legacy / reference dirs (not part of source) — root-anchored so `web/themes/Westlife/` etc. are still tracked
/community/
/v2/
/id/
/Lared/
/Westlife/
/LiMhy_v3.0_正式版/
/blog-main/
/global-ai-bridge/
/HeoMusic-main/
/wordpress-ai-assistant/
/xtools/

# WordPress sync plugin — tracked in a separate repo, not part of main source
/wordpress-plugin/

# Landing + docs sites moved to private sibling repos:
#   github.com/utterlog/utterlog-landing → utterlog.io
#   github.com/utterlog/utterlog-docs    → docs.utterlog.io
# Local checkouts live at ../utterlog-landing and ../utterlog-docs; these
# ignore rules stop accidental re-adds if the dirs get recreated here.
/landing/
/docs/

# Misc
# Root-anchor this so we only drop the stray copy at project root —
# the "real" fonts at web/public/static/fonts/ and api/admin/public/fonts/
# must be committed, otherwise CI Docker builds 404 on the font URL.
/PaperMono-Regular.woff2
backup/

# Reference materials (Typecho CommentAI plugin source for reference)
/Comment/
